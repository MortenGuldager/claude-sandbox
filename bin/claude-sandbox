#!/usr/bin/env bash
# claude-sandbox — manage Incus-based sandboxes for running Claude Code
# against a project directory mounted from the host.
#
# Configuration is read from $CLAUDE_SANDBOX_CONFIG (default
# ~/.config/claude-sandbox/config). All settings have sensible defaults,
# so the tool works out of the box without a config file.
#
# Sandboxes are launched from a cached "base" image whose name embeds a
# hash of the inputs that produced it (source image, package list,
# reporter upstream SHA, schema version). When inputs change, the hash
# changes, and the next `create` builds a fresh base. Stale bases stay
# until removed with `gc` or `rebuild-base`.

set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# Bumped manually when build logic changes in a way not captured by the
# other hash inputs (e.g. we add a new step that doesn't affect any
# tracked file). Forces a rebuild.
BASE_SCHEMA_VERSION=7

# Packages installed into the base image. Order does not matter; the
# hash sorts before digesting. `npm` is intentionally absent — it ships
# bundled with NodeSource's `nodejs`, and Ubuntu's distro `npm` declares
# Conflicts: nodejs against it.
BASE_PACKAGES=(nodejs git curl jq mosquitto-clients inotify-tools)

BASE_ALIAS_PREFIX="claude-sandbox-base-"
BASE_AGE_WARN_DAYS=30

# --- Defaults ---------------------------------------------------------------

SANDBOX_IMAGE="images:ubuntu/24.04"

# Resource limits applied at `create` time. A runaway agent inside the
# sandbox can otherwise exhaust the host's RAM, fill all host swap, and
# pin every CPU. Each is optional — leave blank to inherit Incus's
# default (unlimited).
#
# Note: SANDBOX_MEMORY_SWAP is a *size* cap on swap usage, not a
# boolean. cgroup v2 keeps RAM and swap as two independent budgets, so
# capping RAM alone still lets a runaway process fill all host swap.
# Incus's own `limits.memory.swap` key is only on/off, so we go via
# raw.lxc → `lxc.cgroup2.memory.swap.max` and use cgroup-native suffix
# syntax (K/M/G/T = binary). Total per-sandbox ceiling is therefore
# SANDBOX_MEMORY + SANDBOX_MEMORY_SWAP.
SANDBOX_MEMORY="16GiB"
SANDBOX_MEMORY_SWAP="8G"
SANDBOX_CPU="1"

# Upstream source for the status reporter. `create` fetches this repo at
# the resolved ref into the sandbox and runs its install.sh during the
# base-image build. Override via the config file or the environment if
# you want to test against a fork or pin a specific SHA — unlike the
# other defaults (which only honor the config file), these two also
# honor process-level env vars so one-off testing is friction-free.
REPORTER_REPO="${REPORTER_REPO:-MortenGuldager/claude-status-reporter}"
REPORTER_REF="${REPORTER_REF:-main}"

REPORTER_BACKEND="stdout"
REPORTER_KEEPALIVE=60
REPORTER_FILE_PATH="/var/log/claude-status.jsonl"
REPORTER_MQTT_HOST=""
REPORTER_MQTT_PORT=1883
REPORTER_MQTT_TOPIC=""
REPORTER_MQTT_USER=""
REPORTER_MQTT_PASS=""
REPORTER_HTTP_URL=""

# --- Load user config -------------------------------------------------------

CONFIG_FILE="${CLAUDE_SANDBOX_CONFIG:-$HOME/.config/claude-sandbox/config}"
CONFIG_DIR="$(dirname "$CONFIG_FILE")"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    . "$CONFIG_FILE"
fi

# --- Derived values ---------------------------------------------------------

# Use the resolved real path (not the logical cwd) so that entering the
# project through a symlink and entering it directly land in the same
# sandbox. The realpath is also what gets host-path-preserved as the
# primary mount inside the container.
REPO_DIR="$(realpath .)"
PATH_HASH="$(printf '%s' "$REPO_DIR" | md5sum | cut -c1-6)"
DIR_NAME="$(basename "$REPO_DIR" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]//g')"
CONTAINER_NAME="csb-$DIR_NAME-$PATH_HASH"

# Resolve $REPORTER_REF (a branch or tag) to a concrete commit SHA via the
# GitHub API. Cached on disk for $REPORTER_SHA_CACHE_TTL seconds so common
# read commands (help, info, bases) don't make a network call every time.
# On network failure, falls back to any prior cached value regardless of
# age — keeps offline operation working as long as the cache has been
# warmed once.
REPORTER_SHA_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude-sandbox"
REPORTER_SHA_CACHE_TTL=300

resolve_reporter_sha() {
    local key cache_file age sha
    key="$(printf '%s@%s' "$REPORTER_REPO" "$REPORTER_REF" | md5sum | cut -c1-12)"
    cache_file="$REPORTER_SHA_CACHE_DIR/reporter-sha-$key"

    if [ -f "$cache_file" ]; then
        age=$(( $(date +%s) - $(stat -c %Y "$cache_file") ))
        if [ "$age" -lt "$REPORTER_SHA_CACHE_TTL" ]; then
            cat "$cache_file"
            return 0
        fi
    fi

    sha="$(curl -fsSL --max-time 5 \
        "https://api.github.com/repos/$REPORTER_REPO/commits/$REPORTER_REF" \
        2>/dev/null | jq -r '.sha // empty' 2>/dev/null || true)"

    if [ -n "$sha" ]; then
        mkdir -p "$REPORTER_SHA_CACHE_DIR"
        printf '%s' "$sha" > "$cache_file"
        printf '%s' "$sha"
        return 0
    fi

    if [ -f "$cache_file" ]; then
        cat "$cache_file"
        return 0
    fi

    echo "Could not resolve $REPORTER_REPO @ $REPORTER_REF (check network)." >&2
    echo "Set REPORTER_REF to a specific commit SHA to skip API resolution." >&2
    return 1
}

compute_base_hash() {
    local pkgs_sorted reporter_sha
    pkgs_sorted="$(printf '%s\n' "${BASE_PACKAGES[@]}" | LC_ALL=C sort | tr '\n' ' ')"
    reporter_sha="$(resolve_reporter_sha)" || return 1
    {
        printf 'schema=%s\n'      "$BASE_SCHEMA_VERSION"
        printf 'image=%s\n'       "$SANDBOX_IMAGE"
        printf 'pkgs=%s\n'        "$pkgs_sorted"
        printf 'reporter=%s@%s\n' "$REPORTER_REPO" "$reporter_sha"
    } | sha256sum | cut -c1-12
}

BASE_HASH="$(compute_base_hash)" || exit 1
BASE_ALIAS="${BASE_ALIAS_PREFIX}${BASE_HASH}"
BUILD_CONTAINER="csb-build-${BASE_HASH}"

# --- Helpers ----------------------------------------------------------------

show_help() {
    cat <<EOF
Claude Sandbox Manager
----------------------
Repo:      $REPO_DIR
Container: $CONTAINER_NAME
Base:      local:$BASE_ALIAS
Config:    $CONFIG_FILE $( [ -f "$CONFIG_FILE" ] || echo '(not present; using defaults)' )

Usage: $(basename "$0") <command>[=<arg>] [<command>[=<arg>]...]

Commands run in the given order. The chain aborts on the first failure.

Examples:
  $(basename "$0") setup-token=mogul                            # one-time: mint and store a token
  $(basename "$0") create auth=mogul shell
  $(basename "$0") destroy create auth=mogul dev=ttyACM0 shell
  $(basename "$0") create auth=mogul dev=ttyUSB0,ttyACM0 shell  # multiple devices
  $(basename "$0") create auth=mogul dev shell                  # dev defaults to ttyACM0
  $(basename "$0") create auth=mogul mount=~/Arduino/libraries shell  # extra host dir
  $(basename "$0") create auth=mogul expose=5173 shell          # forward a dev-server port

Commands:
  create               Launch and provision the sandbox container.
                       Builds the base image first if it is missing.
                       Mounts the host cwd at the same path inside the
                       sandbox, forwards the host's global git
                       user.name/email and the host's timezone, and
                       writes runtime notes to ~/.claude/CLAUDE.md
                       inside the sandbox, and pre-accepts Claude
                       Code's first-run prompts (theme, onboarding,
                       folder trust, bypass-permissions). Does NOT set
                       the Claude auth token — chain auth=<profile>
                       after it for that.
  auth=<profile>       Write the Claude auth token from
                       ~/.claudes/<profile>/sandbox-auth into the
                       sandbox. Requires an existing container, so
                       typically chained after create:
                       \`create auth=mogul shell\`.
  setup-token=<profile>
                       Host-side one-time setup: prompts you to run
                       \`claude setup-token\` yourself and paste the
                       resulting token, then stores it at
                       ~/.claudes/<profile>/sandbox-auth so \`auth=\`
                       can pick it up. Refuses to overwrite an existing
                       token without confirmation. Touches no container.
  mount=<path>[,<path>...]
                       Mount one or more extra host directories into
                       the sandbox at the same path as on the host.
                       Each path is realpath'd; symlinks are followed.
                       Additive across calls; re-mounting the same path
                       replaces the existing mount.
  dev[=<port>[,<port>...]]
                       Pass one or more USB/serial devices into the
                       sandbox (default port: ttyACM0). Additive:
                       later dev calls add to, rather than replace,
                       previously passed-through ports.
  expose=<host>[:<container>][,...]
                       Forward a TCP port from the host's loopback into
                       the container's loopback. \`expose=5173\` maps
                       host 127.0.0.1:5173 -> container 127.0.0.1:5173;
                       \`expose=5173:80\` maps different ports. Additive
                       across calls; re-exposing a host port replaces
                       the existing forward.
  shell                Open a login shell inside the sandbox.
  yolo                 Launch Claude inside the sandbox straight away
                       with --dangerously-skip-permissions, skipping
                       the shell. Requires a running container.
  info                 Show sandbox status, mounts, forwarded ports, and
                       passthrough devices.
  list                 List all claude-sandbox containers on the host
                       with their auth profile and primary path.
  start                Start a stopped sandbox (no-op if already running).
  stop                 Stop a running sandbox, preserving its disk state
                       so a later \`start\` resumes it (no-op if already
                       stopped). Use \`destroy\` to also wipe disk.
  destroy              Delete the sandbox container (no-op if absent).
  bases                List cached base images with age and status.
  rebuild-base         Force a rebuild of the current base image.
  gc                   Delete cached base images that don't match the
                       current hash.
  help                 Show this help.
EOF
}

container_exists() {
    incus list --format csv -c n | grep -q "^${1}$"
}

image_alias_exists() {
    incus image list local: --format csv -c l | grep -q "^${1}$"
}

require_container() {
    if ! container_exists "$CONTAINER_NAME"; then
        echo "Sandbox '$CONTAINER_NAME' does not exist. Run: $(basename "$0") create" >&2
        exit 1
    fi
}

get_usb_ids() {
    local dev_name vid pid
    dev_name="$(basename "$1")"
    [ -e "/dev/$dev_name" ] || return 1
    vid="$(udevadm info -a -n "/dev/$dev_name" | grep '{idVendor}'  | head -n1 | cut -d'"' -f2)"
    pid="$(udevadm info -a -n "/dev/$dev_name" | grep '{idProduct}' | head -n1 | cut -d'"' -f2)"
    printf '%s:%s\n' "$vid" "$pid"
}

# Quote a value for use in a systemd EnvironmentFile (also valid when
# bash-sourced). The value is wrapped in double quotes; backslashes,
# double quotes, dollar signs, and backticks are escaped.
quote_env_value() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//\$/\\\$}"
    s="${s//\`/\\\`}"
    printf '"%s"' "$s"
}

# Resolves the Anthropic auth token for a named profile. Profiles live
# under ~/.claudes/<profile>/, mirroring the host-side convention of
# pointing $CLAUDE_CONFIG_DIR at that directory to pick an account. The
# token itself is a single line in sandbox-auth (generated by
# `claude setup-token`). On success, sets RESOLVED_AUTH_TOKEN and
# RESOLVED_AUTH_SOURCE; on failure, prints why and returns non-zero.
resolve_auth_token() {
    local profile="$1"
    RESOLVED_AUTH_TOKEN=""
    RESOLVED_AUTH_SOURCE=""
    local path="$HOME/.claudes/$profile/sandbox-auth"
    if [ ! -f "$path" ]; then
        echo "Profile '$profile' has no token file at $path." >&2
        return 1
    fi
    local t
    t="$(tr -d '[:space:]' < "$path")"
    if [ -z "$t" ]; then
        echo "Profile '$profile' token at $path is empty." >&2
        return 1
    fi
    RESOLVED_AUTH_TOKEN="$t"
    RESOLVED_AUTH_SOURCE="$path"
}

# Writes RESOLVED_AUTH_TOKEN into the container's ~/.bashrc, replacing
# any prior export so `auth` is idempotent and doesn't accumulate lines.
write_auth_token_to_container() {
    incus exec "$CONTAINER_NAME" -- sudo -u ubuntu \
        sed -i '/^export ANTHROPIC_AUTH_TOKEN=/d' /home/ubuntu/.bashrc
    printf "export ANTHROPIC_AUTH_TOKEN=%q\n" "$RESOLVED_AUTH_TOKEN" | \
        incus exec "$CONTAINER_NAME" -- sudo -u ubuntu tee -a /home/ubuntu/.bashrc > /dev/null
}

# Resolves the host's global git identity for forwarding. We use
# host-global on purpose: you're the same person regardless of which
# Claude account a given sandbox uses, so identity doesn't belong with
# the per-account auth token. A repo-local .git/config inside the
# mounted project still wins over this (git's normal precedence).
resolve_git_identity() {
    RESOLVED_GIT_NAME="$(git config --global user.name 2>/dev/null || true)"
    RESOLVED_GIT_EMAIL="$(git config --global user.email 2>/dev/null || true)"
    [ -n "$RESOLVED_GIT_NAME" ] && [ -n "$RESOLVED_GIT_EMAIL" ]
}

write_git_identity_to_container() {
    printf '[user]\n\tname = %s\n\temail = %s\n' \
        "$RESOLVED_GIT_NAME" "$RESOLVED_GIT_EMAIL" | \
        incus exec "$CONTAINER_NAME" -- sudo -u ubuntu \
        tee /home/ubuntu/.gitconfig > /dev/null
}

# Resolves the host's timezone for forwarding into the sandbox. We try
# three sources in order: timedatectl (systemd-style), /etc/timezone
# (debian-style), then the symlink target of /etc/localtime. One of
# these is present on every reasonable host.
resolve_host_timezone() {
    RESOLVED_TZ=""
    if command -v timedatectl >/dev/null 2>&1; then
        RESOLVED_TZ="$(timedatectl show -p Timezone --value 2>/dev/null || true)"
    fi
    if [ -z "$RESOLVED_TZ" ] && [ -f /etc/timezone ]; then
        RESOLVED_TZ="$(tr -d '[:space:]' < /etc/timezone)"
    fi
    if [ -z "$RESOLVED_TZ" ] && [ -L /etc/localtime ]; then
        local link
        link="$(readlink -f /etc/localtime 2>/dev/null || true)"
        case "$link" in
            */zoneinfo/*) RESOLVED_TZ="${link#*/zoneinfo/}" ;;
        esac
    fi
    [ -n "$RESOLVED_TZ" ]
}

write_timezone_to_container() {
    if ! incus exec "$CONTAINER_NAME" -- \
        test -e "/usr/share/zoneinfo/$RESOLVED_TZ"; then
        echo "Note: container has no zoneinfo entry for '$RESOLVED_TZ'; leaving clock at UTC." >&2
        return 1
    fi
    incus exec "$CONTAINER_NAME" -- \
        ln -sf "/usr/share/zoneinfo/$RESOLVED_TZ" /etc/localtime
    printf '%s\n' "$RESOLVED_TZ" | \
        incus exec "$CONTAINER_NAME" -- tee /etc/timezone > /dev/null
}

# Resolves the host's DNS search domain(s) for forwarding. The sandbox's
# eth0 only gets Incus's `incus` domain, so bare hostnames that resolve
# on the host via its search suffix (e.g. `foo` -> `foo.lan`) fail inside
# the sandbox. We read the `search` line from the host's /etc/resolv.conf
# — present and authoritative on every Linux host, and on systemd-resolved
# hosts it already excludes routing-only (~) domains. The container's own
# `incus` domain is dropped so we don't duplicate it.
resolve_host_dns_search() {
    RESOLVED_DNS_SEARCH=""
    local raw d domains=""
    raw="$(awk '/^search[ \t]/ { $1=""; print; exit }' /etc/resolv.conf 2>/dev/null || true)"
    for d in $raw; do
        [ "$d" = "incus" ] && continue
        [ "$d" = "." ] && continue
        domains="${domains:+$domains }$d"
    done
    RESOLVED_DNS_SEARCH="$domains"
    [ -n "$RESOLVED_DNS_SEARCH" ]
}

# Adds the host's search domain(s) as global resolved search domains via
# a drop-in. The eth0 link keeps `incus`, so the container's resolv.conf
# lists the host domains first, then `incus`. DNS *servers* are left as
# Incus's resolver, which forwards unknown queries to the host's upstream
# — so once the suffix is present, host LAN names resolve through it.
write_dns_search_to_container() {
    incus exec "$CONTAINER_NAME" -- mkdir -p /etc/systemd/resolved.conf.d
    printf '[Resolve]\nDomains=%s\n' "$RESOLVED_DNS_SEARCH" | \
        incus exec "$CONTAINER_NAME" -- \
        tee /etc/systemd/resolved.conf.d/claude-sandbox-search.conf > /dev/null
    incus exec "$CONTAINER_NAME" -- systemctl restart systemd-resolved
}

# Paths inside the sandbox where we keep environment notes for Claude.
# The top-level CLAUDE.md is a tiny stub that points at CLAUDE.d/; the
# per-aspect files (00-sandbox.md, device-<port>.md, port-<n>.md) are
# written as the sandbox grows new mappings, so a new aspect just drops
# a new file rather than rewriting one big document.
SANDBOX_CLAUDE_MD="/home/ubuntu/.claude/CLAUDE.md"
SANDBOX_CLAUDE_D="/home/ubuntu/.claude/CLAUDE.d"

# Reads content from stdin and writes it into the sandbox as user ubuntu,
# creating parent directories as needed. Used for the CLAUDE.md stub and
# every CLAUDE.d/ file.
write_sandbox_user_file() {
    local path="$1" dir
    dir="$(dirname "$path")"
    # </dev/null on mkdir so the caller's stdin (heredoc / pipe) is
    # untouched and reaches the tee below intact.
    incus exec "$CONTAINER_NAME" -- sudo -u ubuntu mkdir -p "$dir" </dev/null
    incus exec "$CONTAINER_NAME" -- sudo -u ubuntu tee "$path" > /dev/null
}

write_sandbox_claude_md_stub() {
    write_sandbox_user_file "$SANDBOX_CLAUDE_MD" <<EOF
# Sandbox runtime environment

You are running inside a \`claude-sandbox\` Incus container, not on the
host. Runtime details specific to how this sandbox was launched —
mounted project path, forwarded USB devices, forwarded network ports —
live as individual files in \`$SANDBOX_CLAUDE_D/\`. Read every file
there at the start of the session, and re-read it if you suspect the
environment has changed.
EOF
}

write_sandbox_environment_doc() {
    {
        echo "# Sandbox"
        echo
        echo "- Container name: \`$CONTAINER_NAME\` (Incus, on the host)."
        echo "- Host directories are mounted at the same path inside the sandbox as on the host (see the \`mount-*.md\` files in this directory for the list). Anything outside a mounted directory lives only inside the container and disappears on \`destroy\`."
        echo "- No SSH keys, GPG keys, or cloud credentials from the host are forwarded. Pushing to remotes is a host-side action — ask the user to run it."
        if [ -n "${RESOLVED_TZ-}" ]; then
            echo "- Container clock is set to **$RESOLVED_TZ**, matching the host."
        fi
        if [ -n "${RESOLVED_DNS_SEARCH-}" ]; then
            echo "- DNS search domain is **$RESOLVED_DNS_SEARCH** (forwarded from the host), with Incus's \`incus\` domain appended. Bare hostnames resolve via the host's upstream DNS through the Incus resolver."
        fi
    } | write_sandbox_user_file "$SANDBOX_CLAUDE_D/00-sandbox.md"
}

write_device_doc() {
    local port_name="$1" port_path="$2" vid="$3" pid="$4"
    {
        echo "# USB/serial device: \`$port_path\`"
        echo
        echo "- Passed through from the host."
        echo "- Vendor ID: \`$vid\`  Product ID: \`$pid\`"
        echo "- Accessible at \`$port_path\` inside the sandbox (mode 0666 — no sudo needed)."
    } | write_sandbox_user_file "$SANDBOX_CLAUDE_D/device-$port_name.md"
}

write_mount_doc() {
    local key="$1" host_path="$2" role="$3"
    {
        echo "# Mounted host directory: \`$host_path\`"
        echo
        case "$role" in
            primary)
                echo "- This is the project directory you invoked \`claude-sandbox\` from on the host."
                ;;
            *)
                echo "- Extra directory mounted in via \`claude-sandbox mount=$host_path\`."
                ;;
        esac
        echo "- Mounted read-write at the same path inside the sandbox as on the host. Relative paths and \`..\` work the same on both sides."
        echo "- Changes persist on the host; everything outside any mounted directory lives only inside the container and disappears on \`destroy\`."
    } | write_sandbox_user_file "$SANDBOX_CLAUDE_D/mount-$key.md"
    # Migration: drop the pre-rename doc filename if it survived from
    # before `map=` became `mount=`.
    incus exec "$CONTAINER_NAME" -- sudo -u ubuntu rm -f "$SANDBOX_CLAUDE_D/map-$key.md"
}

# Derives a stable, short, Incus-safe key from an absolute host path.
# Used both for the Incus device name (`claude-mount-<key>`) and the
# per-mount CLAUDE.d filename (`mount-<key>.md`) so re-mounting the
# same path is naturally idempotent.
mount_key_for_path() {
    printf '%s' "$1" | md5sum | cut -c1-10
}

# Project slug matching Claude Code's own convention for naming
# per-project state dirs under `~/.claude/projects/`: the absolute path
# with `/` replaced by `-` (so `/a/b/c` -> `-a-b-c`). Used to bind a
# host-side memory directory to the matching in-sandbox path.
project_slug_for_path() {
    printf '%s' "$1" | tr '/' '-'
}

write_git_doc() {
    {
        echo "# Git"
        echo
        echo "- Default trunk branch is \`main\`, not \`master\`. Use \`main\` when creating branches, opening PRs, or referencing the trunk, unless a specific repo clearly uses a different name."
        if [ -n "${RESOLVED_GIT_NAME-}" ] && [ -n "${RESOLVED_GIT_EMAIL-}" ]; then
            echo "- Commits in this sandbox are authored as \`$RESOLVED_GIT_NAME <$RESOLVED_GIT_EMAIL>\` (forwarded from the host's global \`git config\`). Use this identity in any PR description, commit message, or GitHub interaction that needs to name the author."
        fi
    } | write_sandbox_user_file "$SANDBOX_CLAUDE_D/01-git.md"
}

# Tells Claude that `~/.claude/skills/` and `~/.claude/projects/<slug>/memory/`
# are host-mounted and persist across sandbox lifecycles. Without this note,
# Claude would treat both as ephemeral sandbox state and not realise that
# skills it authors or memory it writes will be available to its future
# selves in fresh sandboxes. Kept terse on purpose — this file is always
# loaded into context. The deeper "when to use which / how to author"
# guidance lives in the seeded `claude-sandbox` skill, which is lazy-loaded
# only when relevant (see seed_claude_sandbox_skill).
write_persistence_doc() {
    local slug
    slug="$(project_slug_for_path "$REPO_DIR")"
    {
        echo "# Persistent Claude state across sandboxes"
        echo
        echo "Two directories under \`~/.claude/\` are host-mounted and survive \`destroy create\`:"
        echo
        echo "- \`~/.claude/skills/\` — shared across **all** of this user's sandboxes (host: \`$CONFIG_DIR/skills/\`)."
        echo "- \`~/.claude/projects/$slug/memory/\` — scoped to this project (host: \`$CONFIG_DIR/memory/$slug/\`)."
        echo
        echo "For conventions — what belongs in a skill vs. memory, how to author each, and what survives container teardown — see the \`claude-sandbox\` skill."
    } | write_sandbox_user_file "$SANDBOX_CLAUDE_D/02-persistence.md"
}

write_port_doc() {
    local host_port="$1" container_port="$2"
    {
        echo "# Forwarded network port: $host_port"
        echo
        if [ "$host_port" = "$container_port" ]; then
            echo "Host \`127.0.0.1:$host_port\` is proxied to the same port inside the container. Bind your service to \`0.0.0.0:$container_port\` (or \`127.0.0.1:$container_port\`) and it is reachable on the host at <http://localhost:$host_port>."
        else
            echo "Host \`127.0.0.1:$host_port\` is proxied to container \`127.0.0.1:$container_port\`. Bind your service to \`0.0.0.0:$container_port\` (or \`127.0.0.1:$container_port\`) inside the sandbox and it is reachable on the host at <http://localhost:$host_port>."
        fi
    } | write_sandbox_user_file "$SANDBOX_CLAUDE_D/port-$host_port.md"
}

# Pre-accepts Claude Code's first-run interactive prompts so a freshly
# created sandbox launches straight into a usable session instead of
# stopping for the theme picker, the onboarding/security notice, the
# per-folder trust dialog, and the bypass-permissions warning. State is
# split across two files Claude reads at startup:
#   ~/.claude/settings.json  theme, skipDangerousModePermissionPrompt
#   ~/.claude.json           hasCompletedOnboarding, lastOnboardingVersion,
#                            and the per-project hasTrustDialogAccepted
#                            flag keyed by the mounted repo path.
# Both are merged with jq rather than overwritten, so anything the base
# image already wrote survives. lastOnboardingVersion is pinned to the
# installed claude version so a version bump doesn't re-trigger the
# onboarding flow. Runs after the container is up; the files normally
# don't exist yet (Claude has never started), hence the `{}` seed.
seed_claude_first_run_state() {
    # Script body runs inside the container as user ubuntu; $1 is the
    # repo path, passed positionally so no host-side expansion happens.
    # `-H` sets HOME so `~` resolves to /home/ubuntu. claude lives in
    # the user-local ~/.local/bin (see build_base_image), which this
    # non-login shell wouldn't otherwise have on PATH.
    # shellcheck disable=SC2016
    incus exec "$CONTAINER_NAME" -- sudo -u ubuntu -H bash -c '
        set -e
        export PATH="$HOME/.local/bin:$PATH"
        repo=$1
        tmp=$(mktemp)
        mkdir -p ~/.claude

        settings=~/.claude/settings.json
        [ -f "$settings" ] || echo "{}" > "$settings"
        jq ".theme = \"dark\" | .skipDangerousModePermissionPrompt = true" \
            "$settings" > "$tmp" && mv "$tmp" "$settings"

        state=~/.claude.json
        [ -f "$state" ] || echo "{}" > "$state"
        ver=$(claude --version 2>/dev/null | grep -oE "[0-9]+\.[0-9]+\.[0-9]+" | head -n1)
        jq --arg repo "$repo" --arg ver "$ver" "
              .hasCompletedOnboarding = true
            | (if \$ver != \"\" then .lastOnboardingVersion = \$ver else . end)
            | .projects[\$repo].hasTrustDialogAccepted = true
        " "$state" > "$tmp" && mv "$tmp" "$state"

        rm -f "$tmp"
    ' _ "$REPO_DIR"
}

write_reporter_env_file() {
    local out="$1"
    {
        printf '%s=%s\n' REPORTER_BACKEND   "$(quote_env_value "$REPORTER_BACKEND")"
        printf '%s=%s\n' REPORTER_KEEPALIVE "$(quote_env_value "$REPORTER_KEEPALIVE")"
        case "$REPORTER_BACKEND" in
            file)
                printf '%s=%s\n' REPORTER_FILE_PATH "$(quote_env_value "$REPORTER_FILE_PATH")"
                ;;
            mqtt)
                printf '%s=%s\n' REPORTER_MQTT_HOST  "$(quote_env_value "$REPORTER_MQTT_HOST")"
                printf '%s=%s\n' REPORTER_MQTT_PORT  "$(quote_env_value "$REPORTER_MQTT_PORT")"
                printf '%s=%s\n' REPORTER_MQTT_TOPIC "$(quote_env_value "$REPORTER_MQTT_TOPIC")"
                printf '%s=%s\n' REPORTER_MQTT_USER  "$(quote_env_value "$REPORTER_MQTT_USER")"
                printf '%s=%s\n' REPORTER_MQTT_PASS  "$(quote_env_value "$REPORTER_MQTT_PASS")"
                ;;
            http)
                printf '%s=%s\n' REPORTER_HTTP_URL "$(quote_env_value "$REPORTER_HTTP_URL")"
                ;;
        esac
    } > "$out"
}

# The reporter is a systemd *user* unit owned by `ubuntu`. We pre-enable
# linger as root so the user manager is up before user-setup.sh runs
# (which keeps the script from having to negotiate polkit under sudo).
# Then we drop our generated config into ~/.config/claude-status-reporter/
# *before* user-setup.sh enables the service, so `enable --now` starts
# with the configured backend rather than the example's stdout default.
enable_reporter_for_ubuntu() {
    local i ubuntu_uid

    # `incus start` returns the moment PID 1 is up, but D-Bus / logind
    # take another second or two to listen. Poll loginctl until it can
    # reach the bus — otherwise the first call below would fail with
    # "Failed to connect to bus: No such file or directory".
    for i in $(seq 1 60); do
        if incus exec "$CONTAINER_NAME" -- loginctl >/dev/null 2>&1; then
            break
        fi
        sleep 0.5
    done

    incus exec "$CONTAINER_NAME" -- loginctl enable-linger ubuntu

    ubuntu_uid="$(incus exec "$CONTAINER_NAME" -- id -u ubuntu)"

    # enable-linger starts user@UID.service asynchronously. Wait until
    # the user manager is reachable before we try `systemctl --user`.
    for i in $(seq 1 60); do
        if incus exec "$CONTAINER_NAME" \
            --user "$ubuntu_uid" --group "$ubuntu_uid" \
            --env "XDG_RUNTIME_DIR=/run/user/$ubuntu_uid" \
            -- systemctl --user show-environment >/dev/null 2>&1; then
            break
        fi
        sleep 0.5
    done

    local config="/home/ubuntu/.config/claude-status-reporter/config.env"
    write_reporter_env_file /dev/stdout | \
        write_sandbox_user_file "$config"
    incus exec "$CONTAINER_NAME" -- chmod 0600 "$config"

    incus exec "$CONTAINER_NAME" \
        --user "$ubuntu_uid" --group "$ubuntu_uid" \
        --cwd /home/ubuntu \
        --env "HOME=/home/ubuntu" \
        --env "USER=ubuntu" \
        --env "LOGNAME=ubuntu" \
        --env "XDG_RUNTIME_DIR=/run/user/$ubuntu_uid" \
        -- /opt/claude-status-reporter/bin/user-setup.sh
}

# Returns the age of the base image in days, or empty if unknown.
base_image_age_days() {
    local uploaded
    uploaded="$(incus image list local: --format json 2>/dev/null | \
        jq -r --arg a "$BASE_ALIAS" '
            .[] | select(.aliases[]?.name == $a) | .uploaded_at
        ' | head -n1)"
    [ -n "$uploaded" ] || return 0
    local then_s now_s
    then_s="$(date -d "$uploaded" +%s 2>/dev/null || echo "")"
    [ -n "$then_s" ] || return 0
    now_s="$(date +%s)"
    echo $(( (now_s - then_s) / 86400 ))
}

# --- Base image build -------------------------------------------------------

build_base_image() {
    echo "Building base image local:$BASE_ALIAS (this is the slow step; subsequent sandboxes reuse it)..."

    if container_exists "$BUILD_CONTAINER"; then
        echo "Build container '$BUILD_CONTAINER' already exists." >&2
        echo "Either another build is in progress, or a previous build crashed." >&2
        echo "If you're sure nothing is running, remove it with:" >&2
        echo "  incus delete -f $BUILD_CONTAINER" >&2
        exit 1
    fi

    # Clean up the build container on any exit path. Don't touch the
    # published image on failure — we only publish on success.
    trap 'incus delete -f "$BUILD_CONTAINER" >/dev/null 2>&1 || true' EXIT

    echo "  Launching build container from $SANDBOX_IMAGE..."
    incus launch "$SANDBOX_IMAGE" "$BUILD_CONTAINER"

    echo "  Waiting for network..."
    # shellcheck disable=SC2016 # script body runs inside the container
    incus exec "$BUILD_CONTAINER" -- bash -c '
        for _ in $(seq 1 30); do
            getent hosts deb.nodesource.com >/dev/null 2>&1 && exit 0
            sleep 1
        done
        echo "network did not come up within 30s" >&2
        exit 1
    '

    echo "  Updating apt index and upgrading packages..."
    incus exec "$BUILD_CONTAINER" -- env DEBIAN_FRONTEND=noninteractive apt-get update
    incus exec "$BUILD_CONTAINER" -- env DEBIAN_FRONTEND=noninteractive apt-get -y upgrade

    echo "  Adding NodeSource repository..."
    incus exec "$BUILD_CONTAINER" -- bash -c \
        "curl -fsSL https://deb.nodesource.com/setup_20.x | bash -"

    echo "  Installing packages: ${BASE_PACKAGES[*]}"
    incus exec "$BUILD_CONTAINER" -- env DEBIAN_FRONTEND=noninteractive \
        apt-get install -y "${BASE_PACKAGES[@]}"

    echo "  Installing @anthropic-ai/claude-code into ubuntu's ~/.local..."
    # Installed as the unprivileged ubuntu user with an npm prefix
    # under its home, not as root into /usr. Claude Code's auto-updater
    # shells out to `npm i -g`; a user-owned prefix keeps that path
    # writable, so updates succeed instead of failing on every launch.
    # The prefix is persisted in ~/.npmrc, which the updater's own npm
    # invocation also reads. `~/.local/bin` is already on PATH via
    # Ubuntu's stock ~/.profile.
    incus exec "$BUILD_CONTAINER" -- sudo -u ubuntu -H bash -c '
        set -e
        npm config set prefix ~/.local
        npm install -g @anthropic-ai/claude-code
    '

    echo "  Installing yolo-claude alias..."
    echo "alias yolo-claude='claude --dangerously-skip-permissions'" | \
        incus exec "$BUILD_CONTAINER" -- sudo -u ubuntu tee -a /home/ubuntu/.bashrc > /dev/null

    echo "  Disabling claude mouse capture via env var..."
    echo "export CLAUDE_CODE_DISABLE_MOUSE=1" | \
        incus exec "$BUILD_CONTAINER" -- sudo -u ubuntu tee -a /home/ubuntu/.bashrc > /dev/null

    # DISABLE_MOUSE stops mouse *reporting* (selection/copy work again) but
    # does NOT stop claude switching to the alternate screen buffer for its
    # fullscreen renderer. On the alt screen the terminal's "alternate scroll"
    # turns the wheel into Up/Down arrows, which the prompt box reads as
    # input-history navigation instead of scrollback. Forcing the classic
    # inline renderer keeps the wheel bound to the terminal's own scrollback.
    echo "  Disabling claude alternate-screen renderer via env var..."
    echo "export CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN=1" | \
        incus exec "$BUILD_CONTAINER" -- sudo -u ubuntu tee -a /home/ubuntu/.bashrc > /dev/null

    # The Incus bridge hands every container a ULA IPv6 address and a default
    # IPv6 route, but the host's uplink has no working IPv6. Apps then prefer
    # AAAA / try IPv6 first and stall on connect timeouts before falling back
    # to IPv4. Disable IPv6 on the external NIC (and any future NIC) so the
    # container has no global IPv6 source address — getaddrinfo() with
    # AI_ADDRCONFIG then stops returning AAAA and apps go straight to IPv4.
    # Loopback (::1) is left enabled so local IPv6-only services still work.
    echo "  Disabling IPv6 in the sandbox (no working IPv6 uplink)..."
    incus exec "$BUILD_CONTAINER" -- tee /etc/sysctl.d/99-disable-ipv6.conf > /dev/null <<'SYSCTL'
net.ipv6.conf.eth0.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
SYSCTL

    # Fetch the status reporter from its own repo. The resolved SHA was
    # baked into BASE_HASH already, so the cached base image is keyed off
    # the exact content we're about to install. The container does the
    # download itself: curl + tar are already present (BASE_PACKAGES and
    # base Ubuntu respectively), and the bytes never have to land on the
    # host.
    local reporter_sha
    reporter_sha="$(resolve_reporter_sha)" || exit 1
    echo "  Fetching $REPORTER_REPO@${reporter_sha:0:12} and installing reporter..."
    # shellcheck disable=SC2016 # script body runs inside the container
    incus exec "$BUILD_CONTAINER" -- bash -c '
        set -e
        mkdir -p /tmp/claude-status-reporter
        curl -fsSL "https://github.com/'"$REPORTER_REPO"'/archive/'"$reporter_sha"'.tar.gz" \
            | tar xz -C /tmp/claude-status-reporter --strip-components=1
        bash /tmp/claude-status-reporter/install.sh
        rm -rf /tmp/claude-status-reporter
    '

    # apt cache cleanup keeps the published image small.
    incus exec "$BUILD_CONTAINER" -- env DEBIAN_FRONTEND=noninteractive \
        apt-get clean

    echo "  Stopping build container..."
    incus stop "$BUILD_CONTAINER"

    echo "  Publishing as local:$BASE_ALIAS..."
    incus publish "$BUILD_CONTAINER" --alias "$BASE_ALIAS" \
        description="claude-sandbox base ($BASE_HASH, schema=$BASE_SCHEMA_VERSION)" >/dev/null

    # Build container is removed by the EXIT trap.
    echo "Base image ready."
}

ensure_base_image() {
    if image_alias_exists "$BASE_ALIAS"; then
        local age
        age="$(base_image_age_days || true)"
        if [ -n "$age" ] && [ "$age" -gt "$BASE_AGE_WARN_DAYS" ]; then
            echo "Note: base image local:$BASE_ALIAS is $age days old."
            echo "      Run '$(basename "$0") rebuild-base' to refresh apt packages and claude-code." >&2
        fi
        return 0
    fi
    build_base_image
}

# --- Commands ---------------------------------------------------------------

cmd_create() {
    if container_exists "$CONTAINER_NAME"; then
        echo "Sandbox '$CONTAINER_NAME' already exists."
        return 0
    fi

    ensure_base_image

    echo "Creating sandbox from local:$BASE_ALIAS..."
    incus init "local:$BASE_ALIAS" "$CONTAINER_NAME" -c security.privileged=true
    incus config set "$CONTAINER_NAME" user.meta.hostpath "$REPO_DIR"
    incus config set "$CONTAINER_NAME" user.meta.base-hash "$BASE_HASH"

    [ -n "$SANDBOX_MEMORY" ]      && incus config set "$CONTAINER_NAME" limits.memory "$SANDBOX_MEMORY"
    [ -n "$SANDBOX_MEMORY_SWAP" ] && incus config set "$CONTAINER_NAME" raw.lxc      "lxc.cgroup2.memory.swap.max=$SANDBOX_MEMORY_SWAP"
    [ -n "$SANDBOX_CPU" ]         && incus config set "$CONTAINER_NAME" limits.cpu   "$SANDBOX_CPU"

    echo "Mounting project directory at $REPO_DIR..."
    attach_mount "$REPO_DIR"

    echo "Mounting persistent skills and memory directories..."
    attach_claude_persistence_mounts

    echo "Starting sandbox..."
    incus start "$CONTAINER_NAME"

    fix_claude_dir_ownership

    echo "Configuring claude-status-reporter (backend=$REPORTER_BACKEND)..."
    enable_reporter_for_ubuntu

    if resolve_git_identity; then
        echo "Forwarding git identity: $RESOLVED_GIT_NAME <$RESOLVED_GIT_EMAIL>"
        write_git_identity_to_container
    else
        echo "Note: host has no global git user.name/user.email; commits in the sandbox" >&2
        echo "      will fail until you set them (on host: 'git config --global ...'" >&2
        echo "      then 'destroy create' to refresh the sandbox)." >&2
    fi

    # Timezone is resolved before the environment doc so the doc can
    # report the resolved value. On failure $RESOLVED_TZ stays empty and
    # the doc just omits the line.
    if resolve_host_timezone; then
        echo "Setting container timezone to $RESOLVED_TZ..."
        write_timezone_to_container || true
    else
        echo "Note: could not resolve host timezone; container clock stays at UTC." >&2
    fi

    # DNS search domain is resolved before the environment doc so the doc
    # can report it. On failure $RESOLVED_DNS_SEARCH stays empty and the
    # doc omits the line; the sandbox keeps just Incus's `incus` domain.
    if resolve_host_dns_search; then
        echo "Forwarding DNS search domain: $RESOLVED_DNS_SEARCH"
        write_dns_search_to_container || true
    else
        echo "Note: host has no DNS search domain to forward; sandbox uses 'incus' only." >&2
    fi

    echo "Writing sandbox environment notes to $SANDBOX_CLAUDE_MD..."
    write_sandbox_claude_md_stub
    write_sandbox_environment_doc
    write_git_doc
    write_persistence_doc
    write_mount_doc "$(mount_key_for_path "$REPO_DIR")" "$REPO_DIR" "primary"

    echo "Pre-accepting Claude Code first-run prompts (theme, onboarding, trust, bypass)..."
    seed_claude_first_run_state

    echo "Sandbox is ready."
}

cmd_auth() {
    local profile="$1"
    require_container
    resolve_auth_token "$profile" || exit 1
    echo "Updating auth token from $RESOLVED_AUTH_SOURCE..."
    write_auth_token_to_container
    incus config set "$CONTAINER_NAME" user.meta.auth-profile "$profile"
    echo "Token updated. New shells will pick it up."
}

# Host-side: prompt the user for a token (produced by `claude setup-token`
# in another terminal) and write it to ~/.claudes/<profile>/sandbox-auth
# where `auth=<profile>` reads from. Fully manual capture — we do not
# spawn `claude setup-token` ourselves, because its interactive output is
# not stable enough to scrape reliably, and because we have not verified
# whether re-running it invalidates prior tokens. Keeping the human in
# the loop sidesteps both issues.
cmd_setup_token() {
    local profile="$1"
    case "$profile" in
        */*|.|..)
            echo "Profile name '$profile' must be a single path segment." >&2
            exit 1
            ;;
    esac

    local dir="$HOME/.claudes/$profile"
    local path="$dir/sandbox-auth"

    if [ -f "$path" ]; then
        echo "A token already exists at $path." >&2
        printf "Overwrite it? [y/N] " >&2
        local reply=""
        IFS= read -r reply </dev/tty || true
        case "$reply" in
            [yY]|[yY][eE][sS]) ;;
            *) echo "Aborted; existing token left in place." >&2; exit 1 ;;
        esac
    fi

    cat >&2 <<EOF

To mint a token, run this on the host (not in a sandbox):

    claude setup-token

It prints a URL — open it in a browser, log in, paste the verification
code back, and it will print a long-lived token. Paste that token here.

EOF

    printf "Token: " >&2
    local token=""
    IFS= read -r token </dev/tty || true
    token="$(printf '%s' "$token" | tr -d '[:space:]')"
    if [ -z "$token" ]; then
        echo "No token entered; aborting." >&2
        exit 1
    fi

    mkdir -p "$dir"
    chmod 700 "$dir"
    # Write to a sibling tmp file and rename, so a Ctrl-C mid-write
    # cannot leave a half-truncated token in place of a previously
    # working one.
    local tmp
    tmp="$(mktemp "$dir/sandbox-auth.XXXXXX")"
    printf '%s\n' "$token" > "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$path"

    echo "Token written to $path"
    echo "Use it with:  $(basename "$0") create auth=$profile shell"
}

cmd_dev() {
    require_container
    local arg="${1:-ttyACM0}"

    # Comma-separated list so `dev=ttyUSB0,ttyACM0` adds both in one
    # call. Each port gets its own Incus device names so subsequent
    # `dev=<port>` calls are additive — remapping one port does not
    # disturb others already passed through.
    local -a names=() vids=() pids=() paths=()
    local raw port_name port_path ids vid pid
    local old_ifs="$IFS"
    IFS=','
    for raw in $arg; do
        port_name="${raw// /}"
        [ -z "$port_name" ] && continue
        port_path="/dev/$port_name"
        if [ ! -e "$port_path" ]; then
            IFS="$old_ifs"
            echo "Device $port_path not found on host." >&2
            exit 1
        fi
        ids="$(get_usb_ids "$port_name" || true)"
        if [ -z "$ids" ] || [ "$ids" = ":" ]; then
            IFS="$old_ifs"
            echo "Could not determine USB IDs for $port_path." >&2
            exit 1
        fi
        vid="${ids%:*}"
        pid="${ids#*:}"
        echo "Identified hardware: $port_path vendor=$vid product=$pid"
        names+=("$port_name")
        vids+=("$vid")
        pids+=("$pid")
        paths+=("$port_path")
    done
    IFS="$old_ifs"

    if [ "${#names[@]}" -eq 0 ]; then
        echo "No ports given." >&2
        exit 1
    fi

    local i usb_dev serial_dev
    for i in "${!names[@]}"; do
        port_name="${names[$i]}"
        port_path="${paths[$i]}"
        vid="${vids[$i]}"
        pid="${pids[$i]}"
        usb_dev="claude-usb-$port_name"
        serial_dev="serial-dev-$port_name"

        incus config device remove "$CONTAINER_NAME" "$usb_dev"    2>/dev/null || true
        incus config device remove "$CONTAINER_NAME" "$serial_dev" 2>/dev/null || true

        incus config device add "$CONTAINER_NAME" "$usb_dev" usb \
            vendorid="$vid" \
            productid="$pid"

        incus config device add "$CONTAINER_NAME" "$serial_dev" unix-char \
            source="$port_path" \
            path="$port_path" \
            mode=0666

        write_device_doc "$port_name" "$port_path" "$vid" "$pid"
        echo "Device passed through: $port_path"
    done
}

# Attaches a single host path as a disk device mounted at the same
# path inside the sandbox. Device-only — does not write the CLAUDE.d
# doc, so this is safe to call before `incus start` (where `incus
# exec` would fail). Caller is responsible for resolving and
# validating the host path, and for arranging that write_mount_doc runs
# once the container is up.
attach_mount() {
    local host_path="$1"
    local key dev_name
    key="$(mount_key_for_path "$host_path")"
    dev_name="claude-mount-$key"

    incus config device remove "$CONTAINER_NAME" "$dev_name" 2>/dev/null || true
    # Migration: drop the pre-rename device name if it lingers on a
    # sandbox created before `map=` became `mount=`.
    incus config device remove "$CONTAINER_NAME" "claude-map-$key" 2>/dev/null || true
    incus config device add "$CONTAINER_NAME" "$dev_name" disk \
        source="$host_path" \
        path="$host_path" >/dev/null
}

# Mounts the two host-side directories that hold Claude state we want
# to survive sandbox destruction: user skills (shared across every
# sandbox) and per-project auto-memory. The in-sandbox target paths
# are the exact locations Claude Code itself uses, so no shim or
# config-file edit is needed — the mount makes the host dir appear at
# the path Claude already scans. Creates the host dirs if missing.
# Device-only — paired CLAUDE.d doc is written by write_persistence_doc
# once the container is up.
attach_claude_persistence_mounts() {
    local skills_host="$CONFIG_DIR/skills"
    local slug memory_host
    slug="$(project_slug_for_path "$REPO_DIR")"
    memory_host="$CONFIG_DIR/memory/$slug"

    mkdir -p "$skills_host" "$memory_host"

    incus config device remove "$CONTAINER_NAME" claude-skills 2>/dev/null || true
    incus config device add "$CONTAINER_NAME" claude-skills disk \
        source="$skills_host" \
        path="/home/ubuntu/.claude/skills" >/dev/null

    incus config device remove "$CONTAINER_NAME" claude-memory 2>/dev/null || true
    incus config device add "$CONTAINER_NAME" claude-memory disk \
        source="$memory_host" \
        path="/home/ubuntu/.claude/projects/$slug/memory" >/dev/null

    seed_claude_sandbox_skill "$skills_host"
}

# Writes a managed skill into the host-mounted skills dir that explains
# the persistence layer in depth — when to use a skill vs. memory, how to
# author each, what survives `destroy create`. It is a skill (not a
# CLAUDE.d note) so it lazy-loads only when relevant, keeping startup
# context lean. Always overwritten on `create` so the guidance tracks
# the tool version; users who want to customise should copy to a
# different directory name (the file itself documents this).
seed_claude_sandbox_skill() {
    local skills_host="$1"
    local skill_dir="$skills_host/claude-sandbox"
    local skill_file="$skill_dir/SKILL.md"
    local slug
    slug="$(project_slug_for_path "$REPO_DIR")"
    mkdir -p "$skill_dir"
    cat > "$skill_file" <<EOF
---
name: claude-sandbox
description: Conventions for the claude-sandbox container's persistent skills/memory infrastructure — when to use which, how to author each, what survives \`destroy create\`. Load before authoring a skill, writing project memory, or troubleshooting files that disappeared after a sandbox rebuild.
---

# How the claude-sandbox persistence layer works

> This file is regenerated by \`claude-sandbox create\` on every run. Local edits are overwritten. To customise, copy the directory to a different name (e.g. \`claude-sandbox.local/\`) so the original path stays free for regeneration.

You are running inside an Incus container managed by \`claude-sandbox\`. The container itself is disposable — \`claude-sandbox destroy create\` wipes container OS state. Three layers survive a rebuild:

1. **The mounted project directory** — same path on host and sandbox, read-write. Anything you commit, build artefact you produce, or file you drop in the project tree persists on the host.
2. **\`~/.claude/skills/\`** — host-mounted at \`$CONFIG_DIR/skills/\`. Shared across every sandbox this user runs (any project, any container).
3. **\`~/.claude/projects/$slug/memory/\`** — host-mounted at \`$CONFIG_DIR/memory/$slug/\`. Scoped to this project's host path. The \`<slug>\` segment is the project realpath with \`/\` replaced by \`-\`, matching Claude Code's own convention.

Everything else under \`~/.claude/projects/$slug/\` (sessions, todos) is ephemeral by design — those are per-conversation state, not knowledge to carry forward. The container OS (\`/etc\`, \`/usr\`, \`/var\`, installed packages, systemd units other than the reporter) is also wiped on \`destroy\`.

## Skills vs. memory — which to use

Use a **skill** when the content is a *procedure or recipe* that could apply in many projects, and you can write a precise \`description\` that names the trigger ("how to set up an Incus VM", "how to debug systemd unit failures"). Skills live in \`~/.claude/skills/\` and are lazy-loaded by description match — they cost nothing when irrelevant, so accumulating them over years is fine.

Use **memory** when the content is a *fact about the user, project, or domain* ("user is a senior Go dev", "release freeze starts 2026-03-05 for mobile cut", "auth rewrite is driven by legal, not tech debt"). Memory lives in \`~/.claude/projects/<slug>/memory/\` and \`MEMORY.md\` is always loaded — keep it terse. Follow the auto-memory conventions in the main system prompt.

Rough rule of thumb: if the content starts with "how to…" it's a skill; if it starts with "X is…" or "we decided…" it's memory.

## Authoring a skill

Create \`~/.claude/skills/<kebab-name>/SKILL.md\`:

\`\`\`markdown
---
name: <kebab-name>
description: <one sentence describing exactly when this skill should fire — be specific; vague descriptions never match>
---

# <human-readable title>

<body — load into context only when the description matches>
\`\`\`

The \`description\` field is the entire gate. "How to do X in environment Y" beats "X helpers". A skill with a vague description is a skill that never loads.

## Authoring memory

Follow the auto-memory rules in the main system prompt. Files land in \`~/.claude/projects/$slug/memory/\` (host: \`$CONFIG_DIR/memory/$slug/\`). \`MEMORY.md\` is the always-loaded index; topic files are pointed to from it. Keep the index under ~150 chars per entry — lines past 200 get truncated.

## When something doesn't persist

If a file is gone after \`destroy create\`, it was outside the three layers above. Most common gotchas:

- Files under \`~/.claude/projects/$slug/\` outside \`memory/\` — sessions and todos go away on purpose.
- Anything under \`/etc\`, \`/usr\`, \`/opt\`, \`/var\` — container OS, ephemeral.
- Files in \`\$HOME\` outside the mounted dirs — ephemeral.
- Packages installed with \`apt\` / \`pip\` / \`npm -g\` — ephemeral. If they need to survive, bake them into the base image (see \`build_base_image\` in \`bin/claude-sandbox\`) or install per-project under the mounted project tree.

## Host-side layout (for the user)

- Skills: \`$CONFIG_DIR/skills/\`
- Memory: \`$CONFIG_DIR/memory/$slug/\`

The user edits or prunes these directly between sandbox lifecycles. There is no in-sandbox CLI for managing them — it's just files on the host.
EOF
}

# Bind-mounting under `~/.claude/` causes Incus to auto-create the
# parent directories (`.claude/`, `.claude/projects/`, `.claude/projects/<slug>/`)
# as root when the container starts. That blocks subsequent file writes
# as the unprivileged `ubuntu` user — including the CLAUDE.md stub and
# the seeded settings.json. Hand the parent dirs back to ubuntu.
# Non-recursive on purpose: the bind-mounted contents underneath
# (skills/, memory/) keep their host ownership untouched.
fix_claude_dir_ownership() {
    local slug
    slug="$(project_slug_for_path "$REPO_DIR")"
    incus exec "$CONTAINER_NAME" -- chown ubuntu:ubuntu \
        /home/ubuntu/.claude \
        /home/ubuntu/.claude/projects \
        "/home/ubuntu/.claude/projects/$slug"
}

# Attach + write the doc + echo. Use this from contexts where the
# container is already running (e.g. cmd_mount). cmd_create attaches
# before start and writes the doc afterwards via write_mount_doc.
add_map_mount() {
    local host_path="$1" role="$2"
    attach_mount "$host_path"
    write_mount_doc "$(mount_key_for_path "$host_path")" "$host_path" "$role"
    echo "Directory mounted: $host_path"
}

# Mounts one or more host directories at the same path inside the
# sandbox. Comma-separated list so `mount=~/a,~/b` adds both in one call.
# Each path is realpath'd (so a symlinked argument lands at its true
# location) and must already exist on the host. Re-mounting a path is
# idempotent — it replaces the existing Incus device.
cmd_mount() {
    require_container
    local arg="$1"

    local -a host_paths=()
    local raw expanded resolved
    local old_ifs="$IFS"
    IFS=','
    for raw in $arg; do
        raw="${raw## }"
        raw="${raw%% }"
        [ -z "$raw" ] && continue
        # Tilde-expand defensively. Bash usually expands `mount=~/foo` at
        # the call site, but quoting (`'mount=~/foo'`) suppresses that,
        # and a config-driven invocation can also arrive un-expanded.
        case "$raw" in
            "~")    expanded="$HOME" ;;
            "~/"*)  expanded="$HOME/${raw#~/}" ;;
            *)      expanded="$raw" ;;
        esac
        if [ ! -e "$expanded" ]; then
            IFS="$old_ifs"
            echo "mount: host path '$expanded' does not exist." >&2
            exit 1
        fi
        if [ ! -d "$expanded" ]; then
            IFS="$old_ifs"
            echo "mount: host path '$expanded' is not a directory." >&2
            exit 1
        fi
        resolved="$(realpath "$expanded")"
        host_paths+=("$resolved")
    done
    IFS="$old_ifs"

    if [ "${#host_paths[@]}" -eq 0 ]; then
        echo "No paths given." >&2
        exit 1
    fi

    local p
    for p in "${host_paths[@]}"; do
        add_map_mount "$p" "extra"
    done
}

# Forwards a TCP port from the host's loopback into the container's
# loopback via an Incus proxy device. Loopback-only on purpose:
# exposing a dev server beyond localhost is rarely what you want, and
# you can always edit the Incus device by hand for the rare case.
# Format: `expose=HOST[:CONTAINER][,...]`. When CONTAINER is omitted,
# the same port number is used on both sides. Additive across calls,
# and re-exposing the same host port replaces the existing forward.
cmd_expose() {
    require_container
    local arg="$1"

    local -a host_ports=() container_ports=()
    local raw host_port container_port
    local old_ifs="$IFS"
    IFS=','
    for raw in $arg; do
        raw="${raw// /}"
        [ -z "$raw" ] && continue
        if [[ "$raw" == *:* ]]; then
            host_port="${raw%%:*}"
            container_port="${raw##*:}"
        else
            host_port="$raw"
            container_port="$raw"
        fi
        if ! [[ "$host_port" =~ ^[0-9]+$ ]] || ! [[ "$container_port" =~ ^[0-9]+$ ]]; then
            IFS="$old_ifs"
            echo "Invalid port spec '$raw' (expected NUM or NUM:NUM)." >&2
            exit 1
        fi
        host_ports+=("$host_port")
        container_ports+=("$container_port")
    done
    IFS="$old_ifs"

    if [ "${#host_ports[@]}" -eq 0 ]; then
        echo "No ports given." >&2
        exit 1
    fi

    local i dev_name
    for i in "${!host_ports[@]}"; do
        host_port="${host_ports[$i]}"
        container_port="${container_ports[$i]}"
        dev_name="claude-port-$host_port"

        incus config device remove "$CONTAINER_NAME" "$dev_name" 2>/dev/null || true

        incus config device add "$CONTAINER_NAME" "$dev_name" proxy \
            listen="tcp:127.0.0.1:$host_port" \
            connect="tcp:127.0.0.1:$container_port" >/dev/null

        write_port_doc "$host_port" "$container_port"
        echo "Port forwarded: host 127.0.0.1:$host_port -> container 127.0.0.1:$container_port"
    done
}

cmd_shell() {
    require_container
    echo "Opening shell in $CONTAINER_NAME..."
    # Land in the same path as the host cwd (host paths are preserved
    # inside the sandbox). Sandboxes are project-scoped, and the prompt
    # still shows the cwd so there's no surprise. Read the mount target
    # back from container metadata rather than the current process cwd,
    # so `shell` from a sibling directory still lands in the right place.
    local mount_path quoted
    mount_path="$(incus config get "$CONTAINER_NAME" user.meta.hostpath)"
    quoted="$(printf '%q' "$mount_path")"
    incus exec "$CONTAINER_NAME" -- sudo --login --user ubuntu \
        bash -c "cd $quoted 2>/dev/null || cd ~; exec bash -i"
}

# Like cmd_shell, but instead of leaving you at a prompt, exec straight
# into Claude with permission prompts disabled. Equivalent to running
# the `yolo-claude` alias by hand after `shell` — it just saves the
# step, since launching Claude this way is what nearly every sandbox
# session does. The sandbox isolation is the load-bearing protection
# that makes --dangerously-skip-permissions acceptable; see the README.
#
# The inner shell must be interactive (`bash -i`): the auth token is
# exported from ~/.bashrc, and Ubuntu's stock .bashrc bails out at the
# top for non-interactive shells, so a plain `bash -c` would launch
# Claude with no ANTHROPIC_AUTH_TOKEN set. This mirrors how cmd_shell
# reaches an interactive shell.
cmd_yolo() {
    require_container
    echo "Launching Claude (--dangerously-skip-permissions) in $CONTAINER_NAME..."
    local mount_path quoted
    mount_path="$(incus config get "$CONTAINER_NAME" user.meta.hostpath)"
    quoted="$(printf '%q' "$mount_path")"
    incus exec "$CONTAINER_NAME" -- sudo --login --user ubuntu \
        bash -c "cd $quoted 2>/dev/null || cd ~; exec bash -ic 'exec claude --dangerously-skip-permissions'"
}

# Format a byte count as a compact IEC string (e.g. 1.4G). Empty,
# non-numeric, or negative input (our sentinel for "unknown") prints "-".
human_bytes() {
    local b="$1"
    if [ -z "$b" ] || ! [ "$b" -ge 0 ] 2>/dev/null; then
        echo "-"
        return
    fi
    numfmt --to=iec "$b" 2>/dev/null || echo "$b"
}

# Disk usage of a sandbox's root, in bytes, or -1 if unknown. Incus only
# populates state.disk.root.usage on quota-aware storage drivers (zfs,
# btrfs, lvm); on the `dir` driver it is absent, so callers that want a
# number there must fall back to `du` inside the container.
disk_usage_bytes() {
    incus list "$1" --format json 2>/dev/null \
        | jq -r '.[0].state.disk.root.usage // -1'
}

# Human-readable root disk usage, given a sandbox's name, status, and the
# storage driver's usage stat in bytes (-1 if the driver has none). Prefers
# the stat; on the dir driver falls back to `du` inside a running container
# (-x keeps it on the root fs, excluding host mounts). Stopped + no stat -> "-".
disk_human() {
    local name="$1" status="$2" bytes="$3" d
    if [ "$bytes" -ge 0 ] 2>/dev/null; then
        human_bytes "$bytes"
    elif [ "${status^^}" = "RUNNING" ]; then
        d="$(incus exec "$name" -- du -shx / 2>/dev/null </dev/null | awk '{print $1}')"
        echo "${d:--}"
    else
        echo "-"
    fi
}

# Live activity summary for a sandbox: what's attached right now. Both
# `csb shell` and `csb yolo` attach via `sudo --login --user ubuntu`, so
# each open session shows up as an ubuntu logind session; a running Claude
# additionally shows up as a `claude` process. We treat the claude sessions
# as the ones holding a `claude` process and the rest as plain shells, and
# render "claude", "shell", "claude+shell", "shell ×N", or "-". The
# always-on status reporter runs as a systemd service, not a login, so it
# never inflates the count. Non-running or unreachable containers show "-".
session_summary() {
    local name="$1" status="$2" out s c shells label sh
    if [ "${status^^}" != "RUNNING" ]; then
        echo "-"
        return
    fi
    out="$(incus exec "$name" -- bash -c '
        s=$(loginctl --no-legend list-sessions 2>/dev/null | grep -wc ubuntu)
        c=$(pgrep -xc claude 2>/dev/null)
        printf "%s %s\n" "${s:-0}" "${c:-0}"
    ' 2>/dev/null </dev/null)"
    read -r s c <<< "$out"
    [ -n "$s" ] || s=0
    [ -n "$c" ] || c=0
    shells=$(( s - c ))
    (( shells < 0 )) && shells=0
    label=""
    if (( c > 0 )); then
        label="claude"
        (( c > 1 )) && label="claude ×$c"
    fi
    if (( shells > 0 )); then
        sh="shell"
        (( shells > 1 )) && sh="shell ×$shells"
        label="${label:+$label+}$sh"
    fi
    echo "${label:--}"
}

cmd_info() {
    if ! container_exists "$CONTAINER_NAME"; then
        echo "No sandbox found for this directory."
        return 0
    fi
    local status mapped base_hash auth_profile cur_mem cur_swap cur_cpu
    status="$(incus info "$CONTAINER_NAME" | awk '/^Status/{print $2}')"
    mapped="$(incus config get "$CONTAINER_NAME" user.meta.hostpath)"
    base_hash="$(incus config get "$CONTAINER_NAME" user.meta.base-hash)"
    auth_profile="$(incus config get "$CONTAINER_NAME" user.meta.auth-profile)"
    cur_mem="$(incus config get "$CONTAINER_NAME" limits.memory)"
    cur_swap="$(incus config get "$CONTAINER_NAME" raw.lxc | sed -n 's/^lxc\.cgroup2\.memory\.swap\.max=//p')"
    cur_cpu="$(incus config get "$CONTAINER_NAME" limits.cpu)"
    local disk_disp
    disk_disp="$(disk_human "$CONTAINER_NAME" "$status" "$(disk_usage_bytes "$CONTAINER_NAME")")"
    echo "Sandbox info:"
    echo "  Name:      $CONTAINER_NAME"
    echo "  Status:    $status"
    echo "  Disk:      $disk_disp"
    echo "  Repo:      $mapped"
    echo "  Auth:      ${auth_profile:-<not set>}"
    echo "  Reporter:  $REPORTER_BACKEND"
    echo "  Built on:  ${base_hash:-<unknown>} (current: $BASE_HASH)"
    if [ -n "$base_hash" ] && [ "$base_hash" != "$BASE_HASH" ]; then
        echo "             (sandbox predates current base; run 'destroy create' to update)"
    fi
    echo
    echo "Limits:"
    echo "  Memory:    ${cur_mem:-<unset>} (config: ${SANDBOX_MEMORY:-<unset>})"
    echo "  Swap:      ${cur_swap:-<unset>} (config: ${SANDBOX_MEMORY_SWAP:-<unset>})"
    [ -n "$cur_swap" ] && \
        echo "             (free(1) inside the sandbox under-reports swap; cgroup memory.swap.max is authoritative)"
    echo "  CPU:       ${cur_cpu:-<unset>} (config: ${SANDBOX_CPU:-<unset>})"
    if [ "$cur_mem" != "$SANDBOX_MEMORY" ] \
        || [ "$cur_swap" != "$SANDBOX_MEMORY_SWAP" ] \
        || [ "$cur_cpu" != "$SANDBOX_CPU" ]; then
        echo "             (sandbox limits differ from config; 'destroy create' to recreate, or 'incus config set $CONTAINER_NAME limits.<key> <val>' to patch in place)"
    fi
    # Bucket devices by type so mounts (disk), forwarded ports (proxy),
    # and hardware passthrough (usb / unix-char) each get their own
    # section. One awk pass over `incus config show --expanded` emits
    # tab-separated records; each section filters and formats from there.
    local devices
    devices="$(incus config show "$CONTAINER_NAME" --expanded | awk '
        /^devices:/                 { in_dev=1; next }
        in_dev && /^[^[:space:]]/   { in_dev=0 }
        !in_dev                     { next }
        /^  [^[:space:]].*:[[:space:]]*$/ {
            if (name) print type "\t" name "\t" source "\t" path "\t" listen "\t" connect "\t" vendor "\t" product
            name=$1; sub(":","",name)
            type=""; source=""; path=""; listen=""; connect=""; vendor=""; product=""
            next
        }
        /^    [^[:space:]]+:/ {
            key=$1; sub(":","",key)
            val=$2; for(i=3;i<=NF;i++) val=val " " $i
            gsub(/^"|"$/, "", val)
            if      (key=="type")      type=val
            else if (key=="source")    source=val
            else if (key=="path")      path=val
            else if (key=="listen")    listen=val
            else if (key=="connect")   connect=val
            else if (key=="vendorid")  vendor=val
            else if (key=="productid") product=val
        }
        END { if (name) print type "\t" name "\t" source "\t" path "\t" listen "\t" connect "\t" vendor "\t" product }
    ')"

    echo
    echo "Mounts (host -> container):"
    local mounts
    mounts="$(awk -F'\t' '$1=="disk" && $3 != "" { print "  " $3 "  ->  " $4 }' <<< "$devices" | sort)"
    if [ -z "$mounts" ]; then
        echo "  (none)"
    else
        echo "$mounts"
    fi

    echo
    echo "Ports (host -> container):"
    local ports
    ports="$(awk -F'\t' '$1=="proxy" { print "  " $5 "  ->  " $6 }' <<< "$devices" \
        | sed 's|tcp:||g' | sort -t: -k2 -n)"
    if [ -z "$ports" ]; then
        echo "  (none — use 'expose=PORT' to forward one)"
    else
        echo "$ports"
    fi

    echo
    echo "Devices:"
    local hw
    hw="$(awk -F'\t' '
        $1=="usb"        { print "  usb " $2 "  vendor=" $7 " product=" $8 }
        $1=="unix-char"  { print "  unix-char " $2 "  " $4 }
    ' <<< "$devices" | sort)"
    if [ -z "$hw" ]; then
        echo "  (none)"
    else
        echo "$hw"
    fi
}

cmd_list() {
    # All sandboxes follow the `csb-<slug>-<hash>` naming scheme. The
    # `csb-build-*` containers are transient artifacts of the base-image
    # build and not real sandboxes, so they get filtered out.
    local rows
    rows="$(incus list --format json 2>/dev/null | jq -r '
        .[]
        | select(.name | startswith("csb-"))
        | select(.name | startswith("csb-build-") | not)
        | [
            .name,
            .status,
            (.config["user.meta.auth-profile"] // "-"),
            (.state.disk.root.usage // -1),
            (.config["user.meta.hostpath"] // "-")
          ]
        | @tsv
    ')"

    if [ -z "$rows" ]; then
        echo "No claude-sandbox containers."
        return 0
    fi

    # DISK comes from the storage driver's stat; on the dir driver (no stat)
    # we `du` inside each running container — cheap at a handful of sandboxes.
    # Stopped containers without a stat show "-".
    printf '  %-32s %-9s %-13s %-12s %-7s %s\n' \
        "NAME" "STATUS" "SESSION" "AUTH" "DISK" "PATH"
    local name status auth disk path
    while IFS=$'\t' read -r name status auth disk path; do
        printf '  %-32s %-9s %-13s %-12s %-7s %s\n' \
            "$name" "$status" "$(session_summary "$name" "$status")" \
            "$auth" "$(disk_human "$name" "$status" "$disk")" "$path"
    done <<< "$rows"
}

cmd_start() {
    require_container
    local status
    status="$(incus info "$CONTAINER_NAME" | awk '/^Status/{print $2}')"
    if [ "$status" = "RUNNING" ]; then
        echo "Sandbox '$CONTAINER_NAME' is already running."
        return 0
    fi
    echo "Starting $CONTAINER_NAME..."
    incus start "$CONTAINER_NAME"
}

cmd_stop() {
    require_container
    local status
    status="$(incus info "$CONTAINER_NAME" | awk '/^Status/{print $2}')"
    if [ "$status" = "STOPPED" ]; then
        echo "Sandbox '$CONTAINER_NAME' is already stopped."
        return 0
    fi
    echo "Stopping $CONTAINER_NAME..."
    incus stop "$CONTAINER_NAME"
}

cmd_destroy() {
    if ! container_exists "$CONTAINER_NAME"; then
        echo "No sandbox to delete."
        return 0
    fi
    incus delete -f "$CONTAINER_NAME"
    echo "Sandbox deleted."
}

cmd_bases() {
    local rows
    rows="$(incus image list local: --format json 2>/dev/null | jq -r \
        --arg prefix "$BASE_ALIAS_PREFIX" \
        --arg current "$BASE_ALIAS" \
        '
            .[]
            | . as $img
            | .aliases[]?
            | select(.name | startswith($prefix))
            | [
                (.name | sub($prefix; "")),
                ($img.uploaded_at // ""),
                ($img.size // 0),
                (if .name == $current then "current" else "stale" end)
              ]
            | @tsv
        ')"

    if [ -z "$rows" ]; then
        echo "No claude-sandbox base images cached."
        echo "Run '$(basename "$0") create' to build one."
        return 0
    fi

    printf 'Base images (current hash: %s)\n\n' "$BASE_HASH"
    printf '  %-14s %-8s %-8s %s\n' "HASH" "AGE" "SIZE" "STATUS"

    local now_s saw_stale=0
    now_s="$(date +%s)"

    while IFS=$'\t' read -r hash uploaded size status; do
        local age size_h then_s
        if [ -n "$uploaded" ] && then_s="$(date -d "$uploaded" +%s 2>/dev/null)"; then
            age="$(( (now_s - then_s) / 86400 ))d"
        else
            age="?"
        fi
        size_h="$(numfmt --to=iec --suffix=B "$size" 2>/dev/null || echo "${size}B")"
        printf '  %-14s %-8s %-8s %s\n' "$hash" "$age" "$size_h" "$status"
        [ "$status" = "stale" ] && saw_stale=1
    done <<< "$rows"

    if [ "$saw_stale" -eq 1 ]; then
        echo
        echo "Run '$(basename "$0") gc' to remove stale bases."
    fi
}

cmd_rebuild_base() {
    if image_alias_exists "$BASE_ALIAS"; then
        echo "Removing existing local:$BASE_ALIAS..."
        incus image delete "local:$BASE_ALIAS"
    fi
    build_base_image
}

cmd_gc() {
    local aliases_csv stale=()
    aliases_csv="$(incus image list local: --format csv -c l 2>/dev/null || true)"
    if [ -z "$aliases_csv" ]; then
        echo "No local images."
        return 0
    fi
    while IFS= read -r alias_line; do
        case "$alias_line" in
            "${BASE_ALIAS_PREFIX}"*)
                if [ "$alias_line" != "$BASE_ALIAS" ]; then
                    stale+=("$alias_line")
                fi
                ;;
        esac
    done <<< "$aliases_csv"

    if [ "${#stale[@]}" -eq 0 ]; then
        echo "Nothing to gc. Current base: local:$BASE_ALIAS"
        return 0
    fi

    echo "Stale base images:"
    printf '  %s\n' "${stale[@]}"
    echo
    read -r -p "Delete these? [y/N] " reply
    case "$reply" in
        y|Y|yes|YES)
            for a in "${stale[@]}"; do
                incus image delete "local:$a"
                echo "  deleted $a"
            done
            ;;
        *)
            echo "Aborted."
            ;;
    esac
}

# --- Dispatch ---------------------------------------------------------------
#
# Tokens are <cmd> or <cmd>=<arg>. Validate the whole chain before running
# anything so a typo can't take the sandbox down halfway through.

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

split_token() {
    TOKEN_CMD="${1%%=*}"
    if [[ "$1" == *=* ]]; then
        TOKEN_ARG="${1#*=}"
        TOKEN_HAS_ARG=1
    else
        TOKEN_ARG=""
        TOKEN_HAS_ARG=0
    fi
}

for token in "$@"; do
    split_token "$token"
    case "$TOKEN_CMD" in
        create|shell|yolo|info|list|start|stop|destroy|bases|rebuild-base|gc|help|-h|--help)
            if [ "$TOKEN_HAS_ARG" -eq 1 ]; then
                echo "Command '$TOKEN_CMD' takes no argument; got '$token'" >&2
                exit 1
            fi
            ;;
        dev)
            ;;
        auth)
            if [ "$TOKEN_HAS_ARG" -ne 1 ] || [ -z "$TOKEN_ARG" ]; then
                echo "Command 'auth' requires a profile, e.g. auth=mogul" >&2
                exit 1
            fi
            ;;
        setup-token)
            if [ "$TOKEN_HAS_ARG" -ne 1 ] || [ -z "$TOKEN_ARG" ]; then
                echo "Command 'setup-token' requires a profile, e.g. setup-token=mogul" >&2
                exit 1
            fi
            ;;
        mount)
            if [ "$TOKEN_HAS_ARG" -ne 1 ] || [ -z "$TOKEN_ARG" ]; then
                echo "Command 'mount' requires an argument, e.g. mount=~/Arduino/libraries" >&2
                exit 1
            fi
            ;;
        map)
            echo "Command 'map' was renamed to 'mount' — use 'mount=$TOKEN_ARG' instead." >&2
            exit 1
            ;;
        expose)
            if [ "$TOKEN_HAS_ARG" -ne 1 ] || [ -z "$TOKEN_ARG" ]; then
                echo "Command 'expose' requires an argument, e.g. expose=5173 or expose=5173:80" >&2
                exit 1
            fi
            ;;
        *)
            echo "Unknown command: '$TOKEN_CMD'" >&2
            echo "Run '$(basename "$0") help' for the list." >&2
            exit 1
            ;;
    esac
done

for token in "$@"; do
    split_token "$token"
    case "$TOKEN_CMD" in
        create)         cmd_create ;;
        auth)           cmd_auth "$TOKEN_ARG" ;;
        setup-token)    cmd_setup_token "$TOKEN_ARG" ;;
        mount)          cmd_mount "$TOKEN_ARG" ;;
        dev)            cmd_dev "$TOKEN_ARG" ;;
        expose)         cmd_expose "$TOKEN_ARG" ;;
        shell)          cmd_shell ;;
        yolo)           cmd_yolo ;;
        info)           cmd_info ;;
        list)           cmd_list ;;
        start)          cmd_start ;;
        stop)           cmd_stop ;;
        destroy)        cmd_destroy ;;
        bases)          cmd_bases ;;
        rebuild-base)   cmd_rebuild_base ;;
        gc)             cmd_gc ;;
        help|-h|--help) show_help ;;
    esac
done
