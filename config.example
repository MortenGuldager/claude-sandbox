# Claude Sandbox configuration
#
# Copy this file to ~/.config/claude-sandbox/config and uncomment the
# settings you want to override. All defaults below match what the tool
# uses when no config file is present, so you only need this file if you
# want to change something.
#
# This file is sourced by bash; quote values that contain spaces.

# --- Sandbox container -----------------------------------------------------

# Incus image to launch.
#SANDBOX_IMAGE="images:ubuntu/24.04"

# Note: there is no SANDBOX_PROJECT_PATH setting. Host directories are
# mounted at the same path inside the sandbox as on the host — `create`
# mounts the cwd implicitly, and `mount=<path>` adds more.

# Note: `create` also auto-mounts two persistence directories so Claude
# state survives sandbox destroy/create cycles, with no setting needed:
#   ~/.config/claude-sandbox/skills/         -> /home/ubuntu/.claude/skills/
#       (user-defined skills, shared across every sandbox)
#   ~/.config/claude-sandbox/memory/<slug>/  -> /home/ubuntu/.claude/projects/<slug>/memory/
#       (auto-memory, scoped to this project's host path)
# `<slug>` is the project realpath with `/` replaced by `-`, matching
# Claude Code's own naming. The host dirs are created on first `create`.

# Resource limits applied at `create` time. A runaway agent inside the
# sandbox can otherwise exhaust the host's RAM, fill all host swap, and
# pin every CPU. Leave any of them blank to inherit Incus's default
# (unlimited). Total per-sandbox memory footprint is capped at
# SANDBOX_MEMORY + SANDBOX_MEMORY_SWAP — the kernel's normal RAM/swap
# balancing still runs unchanged inside those two budgets.
#
# RAM ceiling. When hit, processes inside the sandbox are pushed to
# swap (and OOM-killed if swap is also full). Accepts Incus suffixes
# (KiB/MiB/GiB/...). The default is deliberately conservative — a safety
# belt that also fits an 8GB Pi — so bump it here for memory-hungry work.
#SANDBOX_MEMORY="4GiB"
#
# Swap size cap (not a boolean). cgroup v2 keeps RAM and swap as
# independent budgets, so capping RAM alone does not stop a runaway
# from filling all host swap. Incus's own `limits.memory.swap` is
# only on/off, so this is applied via raw.lxc →
# `lxc.cgroup2.memory.swap.max` and uses cgroup-native suffix syntax
# (K/M/G/T = binary, no "iB").
#SANDBOX_MEMORY_SWAP="2G"
#
# CPU allocation. Accepts a count ("4"), pinned cores ("0,1"), or a
# soft percentage ("50%"). Default of "1" prioritizes host
# responsiveness over build/test throughput in the sandbox.
#SANDBOX_CPU="1"

# Raspberry Pi: the conservative defaults already fit an 8 GB Pi 4/5. You
# may want SANDBOX_CPU="4" for faster builds (the "1" default keeps the
# host responsive), or lower SANDBOX_MEMORY on a 4 GB Pi. The memory/swap
# caps need the cgroup memory controller, which the default Pi kernel
# disables — install.sh offers to add `cgroup_enable=memory cgroup_memory=1`
# to /boot/firmware/cmdline.txt (reboot to apply). See the README's
# Raspberry Pi section. (create warns and runs unlimited if it's missing.)

# Note: the Claude auth token is NOT configured here. Run
# `claude-sandbox auth=<profile>` in the same chain as `create` to
# forward the token from ~/.claudes/<profile>/sandbox-auth into the
# sandbox as ANTHROPIC_AUTH_TOKEN. See README.

# --- Status reporter -------------------------------------------------------
#
# `create` installs claude-status-reporter into the sandbox as a systemd
# service. See https://github.com/MortenGuldager/claude-status-reporter
# for the payload schema, backend details, and the public-MQTT-broker
# warning.

# Upstream source. Override to pin a SHA or test a fork; changing either
# triggers a base-image rebuild on the next `create`.
#REPORTER_REPO="MortenGuldager/claude-status-reporter"
#REPORTER_REF="main"

# Backend: none | stdout | file | mqtt | http.
#REPORTER_BACKEND="stdout"

# Seconds between keep-alive reports (changes are sent immediately).
#REPORTER_KEEPALIVE=60

# --- file backend ----------------------------------------------------------
#REPORTER_FILE_PATH="/var/log/claude-status.jsonl"

# --- mqtt backend ----------------------------------------------------------
# REPORTER_MQTT_TOPIC is the shared ROOT, not a leaf. The reporter appends a
# per-sandbox <node> identity — a non-reversible hash of the container name by
# default — then one retained topic per session under that, so the live topic is:
#   <REPORTER_MQTT_TOPIC>/<node>/<sessionId>  =  "#rrggbb"
# e.g. root "claude_info/status" -> claude_info/status/c7d1caff9ca6/<sessionId>.
# The container name (csb-<project>-<id>) is intentionally NOT in the topic, so
# the project you are working on is not exposed to anyone reading the broker;
# the hash still keeps each sandbox a distinct, stable subtree.
# A session that ends is cleared with an empty retained message. The broker
# must speak MQTT 5 (the reporter connects with -V 5 for the expiry backstop).
#REPORTER_MQTT_HOST="test.mosquitto.org"
#REPORTER_MQTT_PORT=1883
#REPORTER_MQTT_TOPIC=""
#REPORTER_MQTT_USER=""
#REPORTER_MQTT_PASS=""

# --- http backend ----------------------------------------------------------
#REPORTER_HTTP_URL=""
